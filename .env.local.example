# Generic LLM config used by the server-side analysis route.
# For Aliyun DashScope / 百炼 OpenAI-compatible API:
LLM_API_KEY="your-dashscope-api-key"
LLM_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
LLM_MODEL="qwen-plus"

