# ── AI Analysis (main analyze route) ───────────────────────────────────────
# Aliyun DashScope / 百炼 OpenAI-compatible API:
LLM_API_KEY="your-dashscope-api-key"
LLM_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
LLM_MODEL="qwen-plus"

# Example for Google AI Studio:
# LLM_API_KEY="your-google-ai-studio-api-key"
# LLM_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"
# LLM_MODEL="gemini-2.0-flash"

# ── Entry File Deep Analysis (entry/route.ts) ───────────────────────────────
# By default, entry analysis uses the LLM_* config above.
# If you want to force GitHub Models, set GITHUB_USE_MODELS="true".
# Create a Fine-grained PAT at: https://github.com/settings/tokens
# GitHub Models may require additional access depending on your account plan/permissions.
GITHUB_TOKEN="github_pat_your_token_here"

# ── Recursive Callgraph Depth ────────────────────────────────────────────────
# Max recursion depth for call graph analysis (1 = entry only, 2 = one level deep, etc.)
# NEXT_PUBLIC_CALLGRAPH_MAX_DEPTH="2"  # default: 2
# GITHUB_USE_MODELS="true"
# GITHUB_ENTRY_MODEL="gpt-4o-mini"          # default, good balance of speed/quality
# GITHUB_ENTRY_MODEL="gpt-4o"               # slower but more accurate
# GITHUB_MODELS_BASE_URL="https://models.inference.ai.azure.com"  # default, no need to change
